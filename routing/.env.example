# Template for routing/.env. Copy this to .env and fill in real keys.
# .env is gitignored; .env.example IS committed.

# OmniRoute desktop app — issue a key from its UI (/api/keys) or use sk-local-dev-key
# from inside Claude Code (CC-only auth, won't work from raw HTTP).
OMNIROUTE_API_KEY=sk-...

# notion-manager bypass key — paste from notion-manager config.yaml
NOTION_API_KEY=sk-...
