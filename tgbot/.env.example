# tgbot/.env — скопируй в tgbot/.env и заполни. Реальный .env в .gitignore.

# Токен от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Telegram user ID через запятую (узнать у @userinfobot). Whitelist обязателен!
ALLOWED_USERS=111111111

# Дашборд авторегера (должен быть запущен: routing/restart-dashboard.bat)
DASHBOARD_URL=http://localhost:8200

# Папка по умолчанию для claude-сессии (одна из разрешённых корней)
DEFAULT_CWD=C:/Users/WormAlien/Desktop/Autoreger_Clean

# Таймаут одного запроса к claude, мс (по умолч. 600000 = 10 мин)
CLAUDE_TIMEOUT_MS=600000

# --- Голосовые (faster-whisper, локально) ---
# Python из venv (по умолч. ../tools/tg-venv/Scripts/python.exe)
# STT_PYTHON=C:/path/to/python.exe
# Размер модели: tiny/base/small/medium/large-v3 (по умолч. small). base — быстрее, small — точнее.
# WHISPER_MODEL=small
# Устройство: cpu | cuda (по умолч. cpu)
# WHISPER_DEVICE=cpu
